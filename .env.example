# --- Django ---
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (per-service DB) ---
DATABASE_URL=postgres://smarthr_policy:change-me@localhost:5432/smarthr_policy

# --- JWT verification (public key from smarthr360-auth) ---
SMARTHR_JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public.pem
SMARTHR_JWT_ISSUER=smarthr360

# --- Groq LLM (optional; static fallback logic without it) ---
# ROTATE any key that was ever committed to the legacy shared repo!
GROQ_API_KEY=
